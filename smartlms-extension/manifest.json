{
  "manifest_version": 3,
  "name": "SmartLMS Assistant",
  "version": "1.0.0",
  "description": "High-speed YouTube transcript extraction for SmartLMS Teachers.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://*.vercel.app/*",
    "http://localhost:3000/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch?v=*"],
      "js": ["content.js"]
    }
  ]
}
