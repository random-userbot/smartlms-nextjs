# Database (Neon DB)
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname
DATABASE_URL_SYNC=postgresql://user:password@host/dbname

# JWT
JWT_SECRET_KEY=your-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Cloudinary
CLOUDINARY_CLOUD_NAME=ddmanleoz
CLOUDINARY_API_KEY=523164896654715
CLOUDINARY_API_SECRET=DzdKWSA9-gH0UqrDIXN29PeyRcg

# Groq (AI Quiz Generation)
GROQ_API_KEY=your-groq-api-key
GROQ_CHAT_FALLBACK_MODELS=llama-3.1-8b-instant,mixtral-8x7b-32768,gemma2-9b-it
GROQ_AUDIO_FALLBACK_MODELS=whisper-large-v3-turbo

# Debug Mode
DEBUG_MODE=false
DEBUG_LOG_DIR=./debug_logs

# App
APP_ENV=development
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
APP_TRUSTED_ORIGINS=http://localhost:5173
ALLOW_ALL_CORS_IN_DEV=true
AUTO_CREATE_TABLES=true
AUTO_CREATE_INDEXES=true
REQUIRE_SECURE_JWT_IN_PROD=true

# API Rate Limiting (in-memory, per IP+path)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXEMPT_PATHS=/api/health,/docs,/openapi.json,/redoc

# Analytics CPU guardrails
ANALYTICS_MAX_LOG_ROWS=1200
